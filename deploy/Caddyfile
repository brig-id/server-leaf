# brig·id leaf — Caddy reverse proxy configuration
#
# Set the BRIGID_DOMAIN environment variable to your actual domain.
# Caddy reads it at startup and obtains a Let's Encrypt TLS certificate
# automatically.
#
# Production:
#   docker compose -f deploy/compose.yaml up -d

{$BRIGID_DOMAIN} {
    reverse_proxy leaf:8080

    # Security headers (belt-and-suspenders alongside leaf's own headers).
    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
    }

    # Access logging (structured JSON).
    log {
        format json
    }
}
